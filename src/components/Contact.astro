---
<script>
  // Al cargar la página, revisamos los parámetros de la URL
  const urlParams = new URLSearchParams(window.location.search);
  
  if (urlParams.get('success') === 'true') {
    const alert = document.getElementById('success-alert');
    if (alert) {
      alert.classList.remove('hidden'); // Muestra el mensaje
      
      // Opcional: Limpia la URL eliminando el "?success=true" para que no se quede ahí si recargan
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  }
</script>
---

<div class="max-w-7xl mx-auto mt-20 px-6">
  <div
    class="group relative overflow-hidden bg-gradient-to-br from-slate-900 to-blue-950 rounded-3xl p-8 shadow-xl hover:border-slate-500 hover:-translate-y-1 transition-all duration-300"
  >
    <!--border border-slate-700/50-->

    <!-- brillo -->
    <div
      class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent group-hover:translate-x-full transition-transform duration-1000"
    ></div>

    <div class="relative z-10">
      <h2 class="text-3xl font-bold text-white mb-2">Contáctame</h2>

      <p class="text-slate-400 mb-8">Completa el formulario</p>
      <div
        id="success-alert"
        class="hidden mb-6 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-center font-medium shadow-lg shadow-emerald-500/5"
      >
        ¡Gracias! Tu mensaje ha sido enviado con éxito. ✨
      </div>
      <form
        class="flex flex-col gap-5"
        action="https://formsubmit.co/beb429ee6bbd9c3f2ebc9ea87ca209cf"
        method="POST"
      >
        <input
          type="hidden"
          name="_next"
          value="https://gusvalen.github.io/lading-page/?success=true"
        />

        <input type="hidden" name="_captcha" value="false" />

        <input
          class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
          type="text"
          placeholder="Nombre"
          name="name"
          required
        />

        <div>
          <input
            class="peer w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 invalid:focus:ring-red-500 transition"
            type="email"
            placeholder="Correo"
            name="email"
            required
          />

          <!-- <p class="text-red-500 text-sm mt-2 hidden peer-invalid:block">
            Correo incorrecto
          </p> -->
        </div>

        <textarea
          class="w-full h-32 px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
          placeholder="Escribe aquí..."
          name="text"
          required
        ></textarea>

        <button
          class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-semibold py-3 rounded-xl transition-all duration-300 shadow-lg shadow-blue-500/20"
          type="submit"
        >
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</div>
